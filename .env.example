# KHB Doppler-backed environment template
# Use Doppler for real values:
# doppler run --project locus-t-ai-backend --config dev -- corepack pnpm dev
# doppler run --project locus-t-ai-backend --config prd -- corepack pnpm build

# Public runtime values
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=

# Server-only values
SITE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase aliases and optional fallbacks
SUPABASE_ANON_KEY=

# Google Apps Script / Sheets sync
GOOGLE_SHEETS_APPS_SCRIPT_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL_DEV=
RESEND_FROM_EMAIL_PROD=
RESEND_TO_EMAIL_DEV=
RESEND_TO_EMAIL_PROD=

# Optional extra runtime aliases used by the app
WHATSAPP_PHONE_NUMBER=
PUBLIC_GTM_CONTAINER_ID=
PUBLIC_GA4_MEASUREMENT_ID=
